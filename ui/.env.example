# Copy this file to .env.local and fill in your Supabase project values.
# Never put the service role key here — use only the anon key.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Set to 'true' only for local/dev use. Leave false (or unset) in production.
# Also disable signup in Supabase Auth settings for production.
VITE_ENABLE_SIGNUP=false
